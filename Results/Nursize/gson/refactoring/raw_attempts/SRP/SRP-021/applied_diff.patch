+
+    @JsonProperty long updated;
+    @JsonProperty List<Item> items;
+
+    @Override
+    public String toString() {
+      StringBuilder result =
+          new StringBuilder()
+              .append(id)
+              .append('\n')
+              .append(title)
+              .append('\n')
+              .append(description)
+              .append('\n')
+              .append(alternates)
